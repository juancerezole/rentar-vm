{
  "name": "rentar-server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch --no-warnings index.js",
    "start": "node --no-warnings index.js",
    "db:push": "drizzle-kit push",
    "db:setup": "drizzle-kit push && node --no-warnings db/seed.js",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
