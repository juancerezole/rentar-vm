# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS — dominio del frontend
CLIENT_ORIGIN=http://localhost:5173

# trust proxy de Express (necesario para que express-rate-limit identifique IPs reales):
#   false → no confía (default local)
#   true  → confía en todos los hops
#   1     → 1 hop (típico detrás de Render / Vercel / Cloudflare)
#   "loopback, linklocal, uniquelocal" → lista de IPs/CIDRs
TRUST_PROXY=false

# ── JWT (REQUERIDO) ──────────────────────────────────────────────────────────
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# En NODE_ENV=production se exige al menos 32 caracteres y no se aceptan
# valores triviales como "dev-secret" o "changeme".
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── PostgreSQL (Railway o local) ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/rentar_dev
DB_POOL_MAX=10

# Base de datos separada para correr la suite de tests. Si está definida,
# sobrescribe DATABASE_URL al cargar test/setup.js.
TEST_DATABASE_URL=

# ── Datos de prueba ──────────────────────────────────────────────────────────
# "true" sólo en QA y desarrollo local, NUNCA en producción.
SEED_DATA=true

# ── Cloudinary — subida y gestión de imágenes ────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ── Resend — emails transaccionales ──────────────────────────────────────────
# Sin RESEND_API_KEY, los links de password reset se loggean en consola (modo dev).
# RESEND_API_KEY=
EMAIL_FROM=Rentar <noreply@rentar.com.ar>

# ── Meta Conversions API (futuro) ────────────────────────────────────────────
# META_ACCESS_TOKEN=
