PORT=4000
NODE_ENV=development

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiame-en-produccion-string-largo-aleatorio

# CORS
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Railway o local)
DATABASE_URL=postgresql://usuario:password@localhost:5432/rentar_dev

# Cloudinary (se completa cuando se implemente la subida de imágenes)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Resend — emails transaccionales (se completa al implementar recupero de contraseña)
# RESEND_API_KEY=

# Meta Conversions API (futuro, cuando el tráfico lo justifique)
# META_ACCESS_TOKEN=
