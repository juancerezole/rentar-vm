# URL del backend. Si se deja vacío, el proxy de Vite redirige /api → localhost:4000.
VITE_API_URL=http://localhost:4000

# Google Tag Manager (se completa al configurar GTM — Fase 1)
# VITE_GTM_ID=GTM-XXXXXXX

# Cloudinary — cloud name público (no es secreto). Requiere un upload preset
# llamado "rentar_properties" configurado como "unsigned" en el dashboard.
VITE_CLOUDINARY_CLOUD_NAME=tu-cloud-name
